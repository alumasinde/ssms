# SchoolMS — Environment Configuration
# Copy this file to .env and fill in your real values.
# NEVER commit .env to git. It is in .gitignore.

APP_ENV=production
APP_PORT=8080
APP_NAME=SchoolMS

# Database
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=your_db_user
DB_PASS=your_db_password
DB_NAME=school_ms

# JWT — generate a strong secret with: openssl rand -base64 48
JWT_SECRET=CHANGE_ME_use_openssl_rand_base64_48
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=168h

# CORS — comma-separated list of allowed frontend origins
# Do NOT use * in production — list your exact frontend domains
CORS_ALLOWED_ORIGINS=https://app.yourschool.co.ke,https://admin.yourschool.co.ke
